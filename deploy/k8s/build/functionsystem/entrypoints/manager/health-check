#!/bin/bash
set -e

function health_check() {
    if [  $(netstat -plnut | grep tcp | grep 9994 | wc -l | xargs) -eq 0 ]; then
        echo "frontend failed" >> /opt/yuanrong/logs/healthcheck.log
        echo $ret_code >> /opt/yuanrong/logs/healthcheck.log
        exit 1
    fi


    if [  $(netstat -plnut | grep tcp | grep 22423 | wc -l | xargs) -eq 0 ]; then
        echo "proxy failed" >> /opt/yuanrong/logs/healthcheck.log
        echo $ret_code >> /opt/yuanrong/logs/healthcheck.log
